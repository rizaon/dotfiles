#!/bin/sh

unameOut="$(uname -s)"
case "${unameOut}" in
    Darwin*)
	CLANG_FORMAT_HOME=/usr/local/Cellar/clang-format/2019-05-14
	git diff -U0 --no-color HEAD^ \
		| "$CLANG_FORMAT_HOME/share/clang/clang-format-diff.py" \
		-binary "$CLANG_FORMAT_HOME/bin/clang-format" -p1 -i
    Linux*)
        git diff -U0 --no-color HEAD^ | clang-format-diff -p1 -i
    *)          echo "UNKNOWN:${unameOut}"
esac

